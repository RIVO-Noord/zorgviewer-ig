         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "To be usable for a wide range of internationally available applications, the Patient.name.text SHOULD be present." ] ;
         fhir:expression [ fhir:v "text.exists()" ] ;
         fhir:xpath [ fhir:v "/f:name/f:text" ]
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
