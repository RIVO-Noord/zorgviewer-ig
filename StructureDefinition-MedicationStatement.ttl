       fhir:short [ fhir:v "MaximumDose" ] ;
       fhir:definition [ fhir:v "A maximum dose indicates the maximum duration a product can be used with an ‘as needed’ prescription.\r\n\r\nFor example:\r\n- Max 6 units per day\r\n- Max 200ml per week" ] ;
