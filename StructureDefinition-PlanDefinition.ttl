  fhir:snapshot [
     fhir:element ( [
       fhir:id [ fhir:v "PlanDefinition" ] ;
       fhir:path [ fhir:v "PlanDefinition" ] ;
       fhir:short [ fhir:v "The definition of a plan for a series of actions, independent of any specific patient or context" ] ;
       fhir:definition [ fhir:v "This resource allows for the definition of various types of plans as a sharable, consumable, and executable artifact. The resource is general enough to support the description of a broad range of clinical artifacts such as clinical decision support rules, order sets and protocols." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:base [
         fhir:path [ fhir:v "PlanDefinition" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "*" ]
       ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "dom-2" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If the resource is contained in another resource, it SHALL NOT contain nested Resources" ] ;
         fhir:expression [ fhir:v "contained.contained.empty()" ] ;
