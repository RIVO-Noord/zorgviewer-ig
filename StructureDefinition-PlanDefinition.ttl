       fhir:max [ fhir:v "1" ] ;
       fhir:base [
         fhir:path [ fhir:v "Resource.id" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "1" ]
       ] ;
