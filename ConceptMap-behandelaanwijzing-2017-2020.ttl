  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>Mapping from https://zibs.nl/wiki/TreatmentDirective-v3.1(2017EN) to https://zibs.nl/wiki/TreatmentDirective2-v1.0(2020EN)</p><p>ACTIVE. Published on 2024-03-26 12:19:05+0000 by RIVO-NN HL7NL (RIVO-NN: <a href=\"https://rivo-noord.nl\">https://rivo-noord.nl</a>, HL7NL: <a href=\"https://hl7.nl\">https://hl7.nl</a>). </p><div><p>Deze ConceptMap representeert de mapping tussen de BehandelingAanwijzing 2017 en de BehandelAanwijzing2 2020.</p>\n</div><br/><p><b>Group 1</b>Mapping from <code>2.16.840.1.113883.2.4.3.11.60.40.3.2.2</code> to <code>unspecified code system</code></p><table class=\"grid\"><tr><td><b>Source Code</b></td><td><b>Relationship</b></td><td><b>Target Code</b></td></tr><tr><td>Beperkingen</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>SpecificatieAnders</td></tr><tr><td>BeginDatum</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equal\" title=\"equal\">is equal to</a></td><td>MeestRecenteBespreekdatum</td></tr><tr><td>EindDatum</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>DatumBeeindigd</td></tr><tr><td>Toelichting</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equal\" title=\"equal\">is equal to</a></td><td>Toelichting</td></tr></table><hr/><p><b>Group 2</b>Mapping from <code>urn:oid:2.16.840.1.113883.2.4.3.11.60.40.4.25.1</code> to <code>unspecified code system</code></p><table class=\"grid\"><tr><td><b>Source Code</b></td><td><b>Relationship</b></td><td><b>Target Code</b></td></tr><tr><td>JA</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equal\" title=\"equal\">is equal to</a></td><td>0 (Wel uitvoeren)</td></tr><tr><td>NEE</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equal\" title=\"equal\">is equal to</a></td><td>2 (Niet uitvoeren)</td></tr><tr><td>JA_MAAR (Ja, maar met beperkingen)</td><td><a href=\"http://hl7.org/fhir/STU3/codesystem-concept-map-equivalence.html#equivalent\" title=\"equivalent\">is equivalent to</a></td><td>1 (Anders)</td></tr></table></div>"
  ] ; # 
