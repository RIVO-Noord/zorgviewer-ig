         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile [ fhir:v "http://hl7.org/fhir/StructureDefinition/Substance"^^xsd:anyURI ]
       ] ) ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "rim" ] ;
         fhir:map [ fhir:v ".participation[typeCode=DEV].role[classCode=MANU] or\n.participation[typeCode=CSM].role[classCode=ADMM] (for Medication or Substance)" ]
       ] )
     ] [
       fhir:id [ fhir:v "Procedure.usedCode" ] ;
       fhir:path [ fhir:v "Procedure.usedCode" ] ;
       fhir:short [ fhir:v "Coded items used during the procedure" ] ;
       fhir:definition [ fhir:v "Identifies coded items that were used as part of the procedure." ] ;
       fhir:comment [ fhir:v "For devices actually implanted or removed, use Procedure.device." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:base [
         fhir:path [ fhir:v "Procedure.usedCode" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "*" ]
       ] ;
       fhir:type ( [
         fhir:code [ fhir:v "CodeableConcept"^^xsd:anyURI ]
       ] ) ;
       fhir:binding [
         fhir:extension ( [
           fhir:url [ fhir:v "http://hl7.org/fhir/StructureDefinition/elementdefinition-bindingName"^^xsd:anyURI ] ;
           fhir:value [
             a fhir:string ;
             fhir:v "ProcedureUsed"
           ]
         ] ) ;
         fhir:strength [ fhir:v "example" ] ;
         fhir:description [ fhir:v "Codes describing items used during a procedure" ] ;
         fhir:valueSet [
           a fhir:Reference ;
           fhir:link <http://hl7.org/fhir/ValueSet/device-kind> ;
           fhir:reference [ fhir:v "http://hl7.org/fhir/ValueSet/device-kind" ]
         ]
       ] ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "rim" ] ;
         fhir:map [ fhir:v "participation[typeCode=Dev].role[classCode=MANU]" ]
       ] )
     ] )
  ] ; # 
  fhir:differential [
     fhir:element ( [
