         fhir:profile [ fhir:v "http://nictiz.nl/fhir/StructureDefinition/zib-AdministrationSchedule"^^xsd:anyURI ]
       ] ) ;
       fhir:isSummary [ fhir:v "true"^^xsd:boolean ] ;
       fhir:mapping ( [
         fhir:identity [ fhir:v "rim" ] ;
         fhir:map [ fhir:v ".effectiveTime" ]
       ] )
