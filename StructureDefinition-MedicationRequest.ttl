  fhir:snapshot [
     fhir:element ( [
       fhir:id [ fhir:v "MedicationRequest" ] ;
       fhir:path [ fhir:v "MedicationRequest" ] ;
       fhir:short [ fhir:v "MedicationAgreement" ] ;
       fhir:definition [ fhir:v "A medication agreement is a prescriber’s proposal for a patient to use medication. An agreement to discontinue the use of medication is also a medication agreement." ] ;
       fhir:alias ( [ fhir:v "Prescription" ] [ fhir:v "Order" ] [ fhir:v "Medicatieafspraak" ] ) ;
