         fhir:code [ fhir:v "Range"^^xsd:anyURI ]
       ] [
         fhir:code [ fhir:v "Quantity"^^xsd:anyURI ] ;
         fhir:profile [ fhir:v "http://hl7.org/fhir/StructureDefinition/SimpleQuantity"^^xsd:anyURI ]
       ] ) ;
