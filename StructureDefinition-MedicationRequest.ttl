       fhir:short [ fhir:v "Number of refills authorized" ] ;
       fhir:definition [ fhir:v "An integer indicating the number of times, in addition to the original dispense, (aka refills or repeats) that the patient can receive the prescribed medication. Usage Notes: This integer does not include the original order dispense. This means that if an order indicates dispense 30 tablets plus \"3 repeats\", then the order can be dispensed a total of 4 times and the patient can receive a total of 120 tablets." ] ;
       fhir:comment [ fhir:v "If displaying \"number of authorized fills\", add 1 to this number." ] ;
