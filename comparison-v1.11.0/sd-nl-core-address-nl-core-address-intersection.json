        "label" : "Example of a Primary Home address",
        "valueAddress" : {
          "extension" : [{
            "url" : "http://nictiz.nl/fhir/StructureDefinition/zib-AddressInformation-AddressType",
            "valueCodeableConcept" : {
              "coding" : [{
